{
    "debuggingEnabled":false,
    "debuggingReportExecutionTimes":false,
    "requestTimeoutEnabled":true,
    "requestTimeout":"0,0,5,0",
    "robustExceptionEnabled":true,
    "datasources":{
        "${DB_DATABASE}":{
            "host":"${DB_HOST}",
            "dbdriver":"MSSQLServer",
            "database":"${DB_DATABASE}",
            "dsn":"jdbc:macromedia:sqlserver://{host}:{port};databaseName={database};SelectMethod=direct;sendStringParametersAsUnicode=false",
            "port":"${DB_PORT}",
            "class":"${DB_CLASS}",
            "username":"${DB_USER}",
            "password":"${DB_PASSWORD}",
            "maintainConnections":true,
            "maxPooledStatements":"100"
        }
    }
}
