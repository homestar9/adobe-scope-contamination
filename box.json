{
    "name":"My ColdBox App",
    "version":"1.0.0",
    "author":"You",
    "location":"forgeboxStorage",
    "slug":"my-coldbox-app",
    "createPackageDirectory":false,
    "type":"mvc",
    "keywords":"",
    "homepage":"",
    "documentation":"",
    "repository":{
        "type":"",
        "url":""
    },
    "bugs":"",
    "shortDescription":"",
    "contributors":[],
    "ignore":[],
    "devDependencies":{
        "testbox":"*"
    },
    "dependencies":{
        "coldbox":"^8.0.0",
        "quick":"^12.0.0"
    },
    "installPaths":{
        "coldbox":"coldbox/",
        "testbox":"testbox/",
        "quick":"modules/quick/"
    },
    "scripts":{
        "postInstall":"pathExists .env || cp .env.example .env && package set ignore=[]",
        "start:boxlang" : "server start serverConfigFile=server-boxlang-cfml@1.json",
        "start:lucee6" : "server start serverConfigFile=server-lucee@6.json",
        "start:2023" : "server start serverConfigFile=server.json",
        "start:2025" : "server start serverConfigFile=server-adobe@2025.json",
        "stop:boxlang" : "server stop serverConfigFile=server-boxlang-cfml@1.json",
        "stop:lucee6" : "server stop serverConfigFile=server-lucee@6.json",
        "stop:2023" : "server stop serverConfigFile=server.json",
        "stop:2025" : "server stop serverConfigFile=server-adobe@2025.json",
        "forget:boxlang": "server forget serverConfigFile=server-boxlang-cfml@1.json",
        "forget:lucee6": "server forget serverConfigFile=server-lucee@6.json",
        "forget:2023": "server forget serverConfigFile=server.json",
        "forget:2025": "server forget serverConfigFile=server-adobe@2025.json"
    },
    "testbox":{
        "runner":"/tests/runner.cfm"
    },
    "language":"CFML",
    "description":"A ColdBox Application created with the ColdBox CLI"
}
